{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/core-snapshot.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/core-snapshot?market=KOREA",
      "schedule": "0 23 * * *"
    },
    {
      "path": "/api/core-snapshot?market=US",
      "schedule": "30 23 * * *"
    },
    {
      "path": "/api/core-snapshot?market=GLOBAL",
      "schedule": "0 0 * * *"
    }
  ]
}
